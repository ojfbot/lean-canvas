# lean-canvas environment variables
# Copy to .env and fill in values

# API server port
PORT=3021

# Frame agent URL (routes all LLM calls — no direct Anthropic calls)
FRAME_AGENT_URL=http://localhost:4001

# Auth
JWT_SECRET=dev-secret-change-in-production
MOCK_AUTH=true

# CORS
CORS_ORIGIN=http://localhost:3020
